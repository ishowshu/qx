^https:\/\/m5\.amap\.com\/ws\/shield\/search_poi\/tips_adv\? url reject-dict
^https:\/\/oss\.amap\.com\/ws\/banner\/lists\/\? url reject-dict
^https:\/\/m5\.amap\.com\/ws\/aos\/main\/page\/product\/list\? url reject-dict
^https:\/\/m5\.amap\.com\/ws\/faas\/amap-navigation\/(main-page-assets|main-page-location|ridewalk-end-fc) url reject-dict
#  搜索框热词
^https:\/\/m5\.amap\.com\/ws\/(mapapi\/hint_text\/offline_data|message\/notice\/list|shield\/search\/new_hotword) url reject-dict
^https:\/\/m5\.amap\.com\/ws\/shield\/scene\/recommend\? url reject-dict
#  左下角天气
^https:\/\/m5\.amap\.com\/ws\/valueadded\/weather\/v2\? url reject-dict
^https:\/\/sns\.amap\.com\/ws\/msgbox\/pull_mp\? url reject-dict
^https:\/\/m5-zb\.amap\.com\/ws\/boss\/(order\/car\/king_toolbox_car_bubble|tips\/onscene_visual_optimization) url reject-dict
#  搜索结果地图左下角广告图标
^https:\/\/m5\.amap\.com\/ws\/shield\/search_business\/process\/marketingOperationStructured url reject-dict
#  订单页司机信息栏底部无忧行广告
^https:\/\/m5-zb\.amap\.com\/ws\/boss\/order\/car\/rights_information url reject-dict
#  导航打车tab去除顺风车推荐
^https:\/\/m5-zb\.amap\.com\/ws\/boss\/transportation\/diversion\/resource\/driving url reject-dict
#  首页底部ai(如果有下一条规则，那本条规则不会触发
#^https:\/\/ai\.amap\.com\/v1\/ai_rec\/ url reject-dict
#  去除ai功能
^https:\/\/m5\.amap\.com\/ws\/shield\/frogserver\/aocs\/updatable\/ url jsonjq-response-body .data.aiNativeV16={"status":1,"version":"","value":""}|.data.aiNative1520={"status":1,"version":"","value":""}|.data.ai_agent_enter_style_cursor={"status":1,"version":"","value":""}|.data.ai_scenes={"status":1,"version":"","value":""}|.data.aiNativeRC06={"status":1,"version":"","value":""}|.data.plan_ai={"status":1,"version":"","value":""}|.data.ai_native_smart_island={"status":1,"version":"","value":""}|.data.llm={"status":2,"version":"","value":""}
#  新的开屏广告
^https:\/\/amap-aos-info-nogw\.amap\.com\/ws\/aos\/alimama\/splash_screen_rt url reject-dict
#  高德打车广告
^https:\/\/m5-zb\.amap\.com\/ws\/fluorite\/resource url reject-dict
#  高德导航路线详情页底部签到推荐
^https:\/\/m5\.amap\.com\/ws\/aos\/activity\/bus\/sign\/task url reject-dict

